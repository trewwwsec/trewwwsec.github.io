---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featured = posts.slice(0, 3);
---
<BaseLayout>
  <section class="hero section-grid">
    <div class="hero-copy">
      <p class="eyebrow">signal / noise lab</p>
      <h1>Operator mindset. Builder hands. <span class="signal-phrase">Signal-first</span> security.</h1>
      <p class="lede">
        I research, operate, and engineer across offensive and defensive security — turning messy systems into readable signals, attack paths into lessons, and lessons into stronger controls.
      </p>
      <div class="hero-actions">
        <a class="button primary" href="/blog/">Read my research</a>
        <a class="button ghost" href="#work">View operating lanes</a>
      </div>
    </div>
    <aside class="signal-card" aria-label="Trewwwsec operating profile">
      <div class="terminal-bar"><span></span><span></span><span></span></div>
      <pre><code>$ whoami
security engineer

$ focus --mode hybrid
research | operations | engineering

$ current_signal
API abuse, auth flaws, SSTI, practical defense</code></pre>
    </aside>
  </section>

  <section id="work" class="section-block">
    <div class="section-heading">
      <p class="eyebrow">operating lanes</p>
      <h2>Built for the places where theory meets production.</h2>
    </div>
    <div class="card-grid three">
      <article class="feature-card">
        <span class="card-index">01</span>
        <h3>Research</h3>
        <p>CTF and bug-bounty-style analysis translated into practical security patterns: auth boundaries, API behavior, templating risk, and exploit chains.</p>
      </article>
      <article class="feature-card">
        <span class="card-index">02</span>
        <h3>Operations</h3>
        <p>Hands-on operator mindset: enumerate carefully, validate assumptions, keep evidence tight, and move from signal to impact without drama.</p>
      </article>
      <article class="feature-card">
        <span class="card-index">03</span>
        <h3>Engineering</h3>
        <p>Defensive implementation thinking: build controls, automate repeatable checks, and make systems easier to reason about before attackers do.</p>
      </article>
    </div>
  </section>

  <section class="section-block research-band">
    <div class="section-heading split">
      <div>
        <p class="eyebrow">latest research</p>
        <h2>Reposted from Medium, owned here.</h2>
      </div>
      <a class="text-link" href="/blog/">All posts →</a>
    </div>
    <div class="card-grid">
      {featured.map((post) => (
        <article class="post-card">
          <div class="tag-row">
            {post.data.tags.slice(0, 2).map((tag) => <span class="tag">{tag}</span>)}
          </div>
          <h3><a href={`/blog/${post.id}/`}>{post.data.title}</a></h3>
          <p>{post.data.description}</p>
          <div class="post-meta compact">
            <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</time>
            <span>{post.data.readTime}</span>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="contact" class="section-block contact-panel">
    <p class="eyebrow">contact</p>
    <h2>Have a hard security problem or a weird signal worth chasing?</h2>
    <div class="hero-actions">
      <a class="button primary" href="mailto:trewwwsec@gmail.com">trewwwsec@gmail.com</a>
      <a class="button ghost" href="https://github.com/trewwwsec">GitHub</a>
    </div>
  </section>
</BaseLayout>
